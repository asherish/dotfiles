# Interactive shell configuration for zsh.

# --- History ---
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY

# --- Shell Options ---
setopt AUTO_CD
setopt INTERACTIVE_COMMENTS
setopt NO_BEEP

# --- Completion ---
autoload -Uz compinit && compinit

# Case-insensitive and partial-word matching (e.g., "d/kaggle" matches "Documents/kaggle")
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' 'r:|=*' 'l:|=* r:|=*'

# --- Aliases ---
if [[ -x /usr/bin/dircolors ]]; then
    eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
if command -v bat &>/dev/null; then
    alias cat='bat'
fi
if command -v btop &>/dev/null; then
    alias htop='btop'
fi
if command -v eza &>/dev/null; then
    alias ls='eza'
fi

# --- sheldon (Plugin Manager) ---
if command -v sheldon &>/dev/null; then
    eval "$(sheldon source)"
fi

# --- Functions ---

# Select a ghq-managed repository with fzf and cd into it.
# If inside tmux, rename the session to the repository name.
function repo() {
    local moveto
    moveto=$(ghq list --full-path | fzf --height 40% --reverse)
    [[ -z "${moveto}" ]] && return 0
    cd "${moveto}" || return 1

    if [[ -n ${TMUX} ]]; then
        local repo_name
        repo_name="${moveto##*/}"
        tmux rename-session "${repo_name//./-}"
    fi
}

# --- External Tools ---

# mise (Tool Manager)
if [[ -f "$HOME/.local/bin/mise" ]]; then
    eval "$("$HOME/.local/bin/mise" activate zsh)"
fi

# zoxide (Smart cd)
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh)"
fi

# direnv (Per-directory environment)
if command -v direnv &>/dev/null; then
    eval "$(direnv hook zsh)"
fi

# starship (Prompt)
if command -v starship &>/dev/null; then
    eval "$(starship init zsh)"
fi
