{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
# hash: {{ include ".chezmoiscripts/linux/run_onchange_before_05-install-claude-code.sh.tmpl" | sha256sum }}
set -euo pipefail

# The before phase runs before shell config files (dot_zshenv, dot_profile) are deployed,
# so explicitly add ~/.local/bin to PATH (where the claude binary is installed)
export PATH="$HOME/.local/bin:$PATH"

echo "Installing Claude Code..."

if ! command -v claude >/dev/null 2>&1; then
    curl -fsSL https://claude.ai/install.sh | bash
else
    echo "Claude Code is already installed."
fi
{{ end -}}
