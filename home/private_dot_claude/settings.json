{
  "effortLevel": "high",
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "context7@claude-plugins-official": true
  },
  "language": "Japanese",
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skill-evaluation.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "drawio": {
      "type": "stdio",
      "command": "npx",
      "args": ["@jgraph/drawio-mcp"]
    }
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "LS",
      "NotebookRead",
      "TodoRead",
      "WebFetch",
      "WebSearch",

      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",

      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",

      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(column:*)",
      "Bash(tac:*)",
      "Bash(rev:*)",
      "Bash(nl:*)",
      "Bash(paste:*)",
      "Bash(fold:*)",
      "Bash(fmt:*)",
      "Bash(comm:*)",

      "Bash(file:*)",
      "Bash(strings:*)",
      "Bash(md5sum:*)",
      "Bash(sha256sum:*)",
      "Bash(sha1sum:*)",
      "Bash(xxd:*)",
      "Bash(hexdump:*)",
      "Bash(od:*)",

      "Bash(uname:*)",
      "Bash(hostname:*)",
      "Bash(whoami:*)",
      "Bash(id:*)",
      "Bash(date:*)",
      "Bash(uptime:*)",
      "Bash(free:*)",
      "Bash(nproc:*)",
      "Bash(arch:*)",
      "Bash(lsb_release:*)",

      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(pwd:*)",
      "Bash(locale:*)",
      "Bash(which:*)",
      "Bash(type:*)",

      "Bash(ps:*)",
      "Bash(pgrep:*)",

      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)",
      "Bash(ss:*)",

      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git tag:*)",
      "Bash(git stash list:*)",
      "Bash(git blame:*)",
      "Bash(git shortlog:*)",
      "Bash(git describe:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git cat-file:*)",
      "Bash(git rev-list:*)",
      "Bash(git reflog:*)",
      "Bash(git merge-base:*)",
      "Bash(git cherry:*)",
      "Bash(git name-rev:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git config -l:*)",

      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh api:*)",

      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(pip freeze:*)",
      "Bash(npm list:*)",
      "Bash(npm info:*)",
      "Bash(npm ls:*)",

      "Bash(mise list:*)",
      "Bash(mise ls:*)",
      "Bash(mise current:*)",
      "Bash(mise plugins list:*)",

      "Bash(* --version)"
    ]
  }
}
