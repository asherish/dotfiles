# Environment variables for all bash sessions (login shells, sourced by .bashrc for non-login).

export EDITOR=nvim
export VISUAL=nvim

# Ensure ~/.local/bin and ~/bin are in PATH
for dir in "$HOME/.local/bin" "$HOME/bin"; do
    case ":$PATH:" in
        *":$dir:"*) ;;
        *) export PATH="$dir:$PATH" ;;
    esac
done
