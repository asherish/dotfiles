# Starship prompt configuration.
# Catppuccin Powerline gradient ‚ÄĒ colors switch based on environment.
# See https://starship.rs/config/ for available options.

palette = "custom"

format = """
[Óā∂](fg:grad0)\
[{{ if .is_container }} ůį°® {{ else }} ůįēą {{ end }}](bg:grad0 fg:text_light)\
$username\
[@](bg:grad0 fg:text_light)\
$hostname\
[Óāī](fg:grad0 bg:grad1)\
$directory\
[Óāī](fg:grad1 bg:grad2)\
$git_branch\
[Óāī](fg:grad2 bg:grad3)\
$git_status\
[Óāī](fg:grad3 bg:grad4)\
$nodejs$python$rust$golang\
[Óāī](fg:grad4 bg:grad5)\
$time\
[Óāī ](fg:grad5)\
$fill\
$cmd_duration\
$line_break\
$character"""

# --- Modules ----------------------------------------------------------------

[username]
show_always = true
format = "[$user](bg:grad0 fg:text_light)"

[hostname]
ssh_only = false
format = "[$hostname ](bg:grad0 fg:text_light)"

[directory]
format = "[ $path$read_only ]($style)"
style = "bg:grad1 fg:text_dark"
read_only = " ůįĆĺ"
truncation_length = 3
truncate_to_repo = true

[git_branch]
format = "[ ůįė¨ $branch(:$remote_branch) ]($style)"
style = "bg:grad2 fg:text_dark"

[git_status]
format = "[ $all_status$ahead_behind ]($style)"
style = "bg:grad3 fg:text_dark"

[nodejs]
format = "[  $version ]($style)"
style = "bg:grad4 fg:text_dark"
detect_extensions = []

[python]
format = "[  $version ]($style)"
style = "bg:grad4 fg:text_dark"

[rust]
format = "[  $version ]($style)"
style = "bg:grad4 fg:text_dark"

[golang]
format = "[  $version ]($style)"
style = "bg:grad4 fg:text_dark"

[time]
disabled = false
format = "[ ůį•Ē $time ]($style)"
style = "bg:grad5 fg:text_dark"
time_format = "%H:%M"

[fill]
symbol = " "

[cmd_duration]
format = "[ ůĪéę $duration]($style)"
style = "dimmed white"
min_time = 2_000

[line_break]
disabled = false

[character]
success_symbol = "[‚ĚĮ](bold green)"
error_symbol = "[‚ĚĮ](bold red)"

# --- Palette ----------------------------------------------------------------

[palettes.custom]
{{- if .is_container }}
# Docker blue gradient
grad0 = "#2496ED"
grad1 = "#4DABF1"
grad2 = "#77C0F5"
grad3 = "#A1D5F8"
grad4 = "#CBEAFC"
grad5 = "#E5F4FD"
{{- else }}
# Ubuntu orange gradient
grad0 = "#E95420"
grad1 = "#ED7448"
grad2 = "#F19470"
grad3 = "#F5B498"
grad4 = "#F9D4C0"
grad5 = "#FCE9DF"
{{- end }}
text_dark = "#11111b"
text_light = "#cdd6f4"
