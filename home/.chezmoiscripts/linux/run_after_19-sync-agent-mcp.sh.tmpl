{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$PATH"

if ! command -v sync-agent-mcp >/dev/null 2>&1; then
  echo "sync-agent-mcp not found, skipping MCP sync"
  exit 0
fi

echo "Syncing shared MCP servers to Claude Code and Codex..."
sync-agent-mcp
{{ end -}}
