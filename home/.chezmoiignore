# .chezmoiignore
#
# Strategy:
#   1. "*" ignores all files and directories
#   2. "!" allows specific entries through
#   3. To allow contents of a directory, the parent must be allowed first
#
# Patterns refer to target (home directory) paths, not source paths.

*                              # Ignore everything; entries below opt back in with "!"

# --- Top-level dotfiles ------------------------------------------------------

{{ if eq .chezmoi.os "windows" }}
!.bashrc                       # Git Bash interactive shell config
!.profile                      # Git Bash environment config
{{ else if .is_container }}
!.bashrc                       # Bash interactive shell config (container)
!.profile                      # Bash environment config (container)
{{ else }}
!.zshenv                       # Zsh environment config
!.zshrc                        # Zsh interactive shell config
{{ end }}
!.gitconfig                    # Git global config

{{ if ne .chezmoi.os "windows" }}
!.tmux.conf                    # tmux config (Linux only)
!.tmux                         # tmux plugin/script directory
!.tmux/**
{{ else }}
!.wezterm.lua                  # WezTerm terminal emulator config (Windows only)
{{ end }}

# --- .config/* (Linux only) --------------------------------------------------

{{ if ne .chezmoi.os "windows" }}
!.config                       # XDG config base directory

!.config/nvim                  # Neovim config
!.config/nvim/init.lua         # Entry point for Neovim configuration
!.config/nvim/lazyvim.json     # LazyVim extras enablement settings
!.config/nvim/stylua.toml      # StyLua formatter config
!.config/nvim/lua              # Lua config directory
!.config/nvim/lua/**

!.config/lazygit               # Lazygit TUI config
!.config/lazygit/**

!.config/gh                    # GitHub CLI config
!.config/gh/config.yml         # Exclude hosts.yml as it contains tokens

!.config/starship.toml         # Starship prompt config

!.config/mise                  # mise config
!.config/mise/**

{{ if not .is_container }}
!.config/sheldon               # sheldon plugin manager config
!.config/sheldon/**
{{ end }}

!.config/yazi                  # Yazi file manager config
!.config/yazi/**
{{ end }}

# --- .claude/* ---------------------------------------------------------------

!.claude                       # Claude Code config directory
!.claude/CLAUDE.md             # Global instructions for Claude Code
!.claude/settings.json         # Claude Code settings
!.claude/hooks                 # Claude Code hooks directory
!.claude/hooks/**
